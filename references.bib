  shorttitle = {Polynomial {{Regression}} with {{Response Surface Analysis}}},
  author = {Shanock, Linda Rhoades and Baran, Benjamin E. and Gentry, William A. and Pattison, Stacy Clever and Heggestad, Eric D.},
