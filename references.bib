}

@article{rushInventoryDepressiveSymptomatology1986,
  title = {The Inventory for Depressive Symptomatology ({{IDS}}): {{Preliminary}} Findings},
  shorttitle = {The Inventory for Depressive Symptomatology ({{IDS}})},
  author = {Rush, A John. and Giles, Donna E. and Schlesser, Michael A. and Fulton, Carl L. and Weissenburger, Jan and Burns, Cheryl},
  year = 1986,
