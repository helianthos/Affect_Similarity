  author = {Wright, Aidan G. C. and Hallquist, Michael N. and Morse, Jennifer Q. and Scott, Lori N. and Stepp, Stephanie D. and Nolf, Kimberly A. and Pilkonis, Paul A.},
  year = 2013,
  month = apr,
