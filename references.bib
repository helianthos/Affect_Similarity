@article{kalkan-cengizCouplesInterpersonalBehavior2025,
  title = {Couples' Interpersonal Behavior and Depressive Symptoms at the Trait and State-Level},
  author = {{Kalkan-Cengiz}, Rana B. and Verhees, Martine W. F. T. and Sels, Laura and Kuppens, Peter},
  year = 2025,
  month = jul,
  journal = {Motivation and Emotion},
  issn = {0146-7239, 1573-6644},
  doi = {10.1007/s11031-025-10157-7},
  urldate = {2025-09-17},
  abstract = {Increasingly, psychopathology is studied from an explicit interpersonal perspective, focusing on the two fundamental dimensions of interpersonal functioning: agency and communion. While theories of depression and empirical findings indicate the significance of agentic and communal behaviors in depression and overall well-being, there has not been a thorough examination of depressive symptoms in relation to agentic and communal behaviors in social interactions. To address this gap, in the present study, we examined how daily life own and perceived partner agentic and communal behavior (operationalized as dominant vs. submissive, and warm vs. cold behaviors), and complementarity between partners (i.e., contrastive agentic and symmetrical communal behavior) relate to depressive symptomatology at the trait level, and negative and positive affect at the state level. The data were collected in 2014-2015 from 50 Dutch-speaking heterosexual romantic couples using experience sampling methodology (ESM). Couples reported on depressive symptoms before the ESM period, and reported on their own and perceived partner agentic and communal behavior, and affect 10 times per day for 7 days. Contrary to our hypotheses, neither aggregated own and perceived partner interpersonal behavior nor momentary complementarity was related to depressive symptomatology. At the state level, we found that positive and negative affect were predicted by momentary own and perceived agentic and communal behavior separately, not necessarily by complementarity in own and perceived partner behavior. Moreover, communal behaviors explained more variance in momentary affect than agentic behaviors. Overall, our findings suggest that agentic and communal behaviors have implications for affect, however, contrary to interpersonal theory, complementarity of interpersonal behaviors between partners at the momentary level is not necessarily associated with momentary affect.},
  langid = {english},
  file = {/Users/geert/Zotero/storage/4434M4YY/Kalkan-Cengiz et al. - 2025 - Couples’ interpersonal behavior and depressive symptoms at the trait and state-level.pdf}
}

