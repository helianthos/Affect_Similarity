  file = {/Users/geert/Zotero/storage/A3AQ34F3/Russell and Barrett - 1999 - Core affect, prototypical emotional episodes, and other things called emotion Dissecting the elepha.pdf;/Users/geert/Zotero/storage/AY9G8HHJ/doiLanding.html}
