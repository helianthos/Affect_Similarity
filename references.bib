@article{humbergImprovingProbabilityReaching2025,
  title = {Improving the Probability of Reaching Correct Conclusions about Congruence Hypotheses: {{Integrating}} Statistical Equivalence Testing into Response Surface Analysis},
  shorttitle = {Improving the Probability of Reaching Correct Conclusions about Congruence Hypotheses},
  author = {Humberg, Sarah and Sch{\"o}nbrodt, Felix D. and Nestler, Steffen},
  year = 2025,
  journal = {Psychological Methods},
  publisher = {American Psychological Association},
  address = {US},
  issn = {1939-1463},
  doi = {10.1037/met0000743},
  abstract = {Many psychological theories imply that the degree of congruence between two variables (e.g., self-rated and objectively measured intelligence) is related to some psychological outcome (e.g., life satisfaction). Such congruence hypotheses can be tested with response surface analysis (RSA), in which a second-order polynomial regression model is estimated and suitably interpreted. Whereas several strategies exist for this interpretation, they all contain rationales that diminish the probability of drawing correct conclusions. For example, a frequently applied strategy involves calculating six auxiliary parameters from the estimated regression weights and accepting the congruence hypothesis if they satisfy certain conditions. In testing the conditions, a nonsignificant null-hypothesis test of some parameters is taken as evidence that the parameter is zero. This interpretation is formally inadmissible and adversely affects the probability of making correct decisions about the congruence hypothesis. We address this limitation of the six-parameter strategy and other RSA strategies by proposing that statistical equivalence testing (SET) be integrated into RSA. We compare the existing and new RSA strategies with a simulation study and find that the SET strategies are sensible alternatives to the existing strategies. We provide code templates for implementing the SET strategies. (PsycInfo Database Record (c) 2025 APA, all rights reserved)},
  keywords = {Hypothesis Testing,Measurement Invariance,Probability,Statistical Analysis,Statistical Probability},
  file = {/Users/geert/Zotero/storage/4GTRPEIR/Humberg et al. - 2025 - Improving the probability of reaching correct conclusions about congruence hypotheses Integrating s.pdf;/Users/geert/Zotero/storage/ELS3ZHT7/2025-84320-001.html}
}

@article{humbergInvestigatingEffectsCongruence2024,
  title = {Investigating the Effects of Congruence between Within-Person Associations: {{A}} Comparison of Two Extensions of Response Surface Analysis},
  shorttitle = {Investigating the Effects of Congruence between Within-Person Associations},
  author = {Humberg, Sarah and Kuper, Niclas and Rentzsch, Katrin and Gerlach, Tanja M. and Back, Mitja D. and Nestler, Steffen},
  year = 2024,
  month = sep,
  journal = {Psychological Methods},
  publisher = {American Psychological Association},
  address = {Washington, US},
  issn = {1082-989X},
  doi = {10.1037/met0000666},
  urldate = {2025-11-19},
  abstract = {Response surface analysis (RSA) allows researchers to study whether the degree of congruence between two predictor variables is related to a potential psychological outcome. Here, we adapt RSA to the case in which the two predictor variables whose congruence is of interest refer to individual differences in within-person associations (WPAs) between variables that fluctuate over time. For example, a WPA-congruence hypothesis in research on romantic relationships could posit that partners are happier when they have similar social reactivities---that is, when they have similarly strong WPAs between the quantity of their social interactions and their momentary well-being. One method for testing a WPA-congruence hypothesis is a two-step approach in which the individuals' WPAs are first estimated as random slopes in respective multilevel models, and then these estimates are used as predictors in a regular RSA. As an alternative, we suggest combining RSA with multilevel structural equation modeling (MSEM) by specifying the WPAs as random slopes in the structural equation and using their latent second-order terms to predict the outcome on Level 2. We introduce both approaches and provide and explain their corresponding computer code templates. We also compared the two approaches with a simulation study and found that the MSEM model---despite its complexities (e.g., nonlinear functions of latent slopes)---has advantages over the two-step approach. We conclude that the MSEM approach should be used in practice. We demonstrate its application using data from a daily diary study and offer guidance for important decisions (e.g., about standardization). (PsycInfo Database Record (c) 2025 APA, all rights reserved) (Source: journal abstract) Response surface analysis is a statistical tool that is used, for example, to study whether the degree of congruence between two person-level trait variables relates to a third variable (e.g., whether romantic couples whose partners have similar personality trait levels are happier than incongruent couples). A complementary perspective on congruence hypotheses refers to within-person dynamics instead of person-level trait variables. For example, are those romantic couples more satisfied whose partners are similar in terms of their social reactivity---that is, who have similar within-person associations (WPAs) between the quantity of their social interactions and their momentary well-being? In the present article, we aim to equip applicants with the necessary statistical tools to investigate such ``WPA-congruence hypotheses.'' We consider two potential analytical approaches to this aim, namely a two-step approach and an approach using multilevel structural equation modeling (MSEM). Based on the results of a simulation study in which we compared the two approaches, we recommend to use MSEM in practice. We support the application of this complex method by providing and explaining code templates, showcasing the application and interpretation using real data from a daily diary study, and offering guidance on key decisions (e.g., referring to commensurability and standardization). We also discuss the broad applicability of the approach, which can pertain to various phenomena (e.g., consequences of similarity, accuracy, stability, consistency, and person--environment fit) and to both dyads (e.g., romantic couples, friends, parent--child, therapist--patient, teacher--student, employer--employee, and politician--citizen) or single individuals. (PsycInfo Database Record (c) 2025 APA, all rights reserved)},
  copyright = {\copyright{} 2024, American Psychological Association. All rights, including for text and data mining, AI training, and similar technologies, are reserved.},
  langid = {english},
  keywords = {Individual Differences,Longitudinal Studies,Repeated Measures,Statistical Analysis,Statistical Data,Structural Equation Modeling},
  file = {/Users/geert/Zotero/storage/WDYIDCG9/Humberg et al. - 2024 - Investigating the effects of congruence between within-person associations A comparison of two exte.pdf}
}

