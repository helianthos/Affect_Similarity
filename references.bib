  publisher = {Lawrence Erlbaum Associates Publishers},
  address = {Mahwah, NJ, US},
  abstract = {Research on the effects of person-environment (PE) fit reflects three overriding assumptions. First, it is generally assumed that PE fit leads to positive outcomes. Second, it is often assumed that the effects of PE fit are the same across different person and environment constructs. Third, it is widely assumed that the effects of PE fit are the same regardless of the absolute levels of the person and environment or the direction of their difference. In this chapter, we outline an approach to conceptualizing the effects of PE fit that probes those assumptions. The conceptual approach we describe is intended to encourage PE fit researchers to critically examine assumptions that characterize the investigation of the effects of PE fit on outcomes, with the ultimate goal of advancing our collective understanding of PE fit. Our goal is to demonstrate a general approach to theorizing the effects of PE fit that can be applied and extended in various specific streams of PE fit research. Although some aspects of our presentation suggest hypotheses to be tested, our chief objective is to provide some initial conceptual spadework that delves into assumptions that underlie PE fit research, with the hope that these assumptions will be further probed in future PE fit research. (PsycInfo Database Record (c) 2025 APA, all rights reserved)},
  isbn = {978-0-8058-5195-3 978-1-4106-1778-1},
  keywords = {Person Environment Fit,Theoretical Orientation},
  file = {/Users/geert/Zotero/storage/GCWM38ET/Edwards and Shipp - 2007 - The relationship between person-environment fit and outcomes An integrative theoretical framework.pdf;/Users/geert/Zotero/storage/2BBAC7WL/2007-15682-007.html}
}

